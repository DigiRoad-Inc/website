{
  "hosting": {
    "site": "digiroad-website",
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      ".git/**",
      ".gitignore",
      "**/.*",
      "**/node_modules/**",
      "supabase/**",
      "vite.config.*",
      "package*.json",
      "dist/**"
    ],
    "headers": [
      {
        "source": "**/*.@(css|js)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000" }
        ]
      },
      {
        "source": "**/*.@(png|jpg|jpeg|webp|svg|ico|gif)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000" }
        ]
      }
    ]
  }
}
